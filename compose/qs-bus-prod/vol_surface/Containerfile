FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
  && rm -rf /var/lib/apt/lists/*

# ZMQ + Redpanda (Kafka protocol) client
RUN python -m pip install --no-cache-dir -U pip \
 && python -m pip install --no-cache-dir pyzmq confluent-kafka

CMD ["python", "zmq_surface_service.py"]
